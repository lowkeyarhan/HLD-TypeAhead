http://localhost, http://127.0.0.1, http://typeahead.localhost {
    redir https://{host}{uri} permanent
}

https://localhost, https://127.0.0.1 {
    tls internal
    encode zstd gzip
    reverse_proxy client:3000
}

https://typeahead.localhost {
    tls internal
    encode zstd gzip
    reverse_proxy client:3000
}
